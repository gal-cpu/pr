<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4FF"
    tools:context=".AddItem">

    <!-- Top gradient header bar -->
    <View
        android:id="@+id/headerBar"
        android:layout_width="0dp"
        android:layout_height="200dp"
        android:background="@drawable/bg_header_gradient"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Back button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAddItemBack"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="12dp"
        android:text="← Back"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Header title -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="56dp"
        android:text="Add New Item"
        android:textColor="#FFFFFF"
        android:textSize="32sp"
        android:textStyle="bold"
        android:letterSpacing="0.02"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Fill in the details below"
        android:textColor="#DDEEFF"
        android:textSize="15sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTitle" />

    <!-- Main scrollable content card -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="160dp"
        android:layout_marginStart="0dp"
        android:layout_marginEnd="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:paddingTop="0dp"
            android:paddingBottom="32dp">

            <!-- Main form card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="24dp"
                app:cardElevation="8dp"
                app:strokeColor="#E8EEFF"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Section label -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:text="Item Details"
                        android:textColor="#4A67E0"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1" />

                    <!-- Item Name -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:hint="Item Name"
                        app:boxBackgroundColor="#F5F7FF"
                        app:boxBackgroundMode="filled"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxStrokeColor="#4A67E0"
                        app:hintTextColor="#4A67E0"
                        app:startIconDrawable="@drawable/ic_label"
                        app:startIconTint="#4A67E0">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etItemName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="#1A1A2E"
                            android:textSize="15sp" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:id="@+id/TvPnameMessage"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:layout_marginBottom="12dp"
                        android:text=""
                        android:textColor="#E53935"
                        android:textSize="12sp" />

                    <!-- Item Type -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:hint="Item Type (book / toy / shoe / device)"
                        app:boxBackgroundColor="#F5F7FF"
                        app:boxBackgroundMode="filled"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxStrokeColor="#4A67E0"
                        app:hintTextColor="#4A67E0"
                        app:startIconDrawable="@drawable/ic_category"
                        app:startIconTint="#4A67E0">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etItemType"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="#1A1A2E"
                            android:textSize="15sp" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:id="@+id/TvPtypeMessage"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:layout_marginBottom="12dp"
                        android:text=""
                        android:textColor="#E53935"
                        android:textSize="12sp" />

                    <!-- Item Note -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:hint="Description / Note"
                        app:boxBackgroundColor="#F5F7FF"
                        app:boxBackgroundMode="filled"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxStrokeColor="#4A67E0"
                        app:hintTextColor="#4A67E0"
                        app:startIconDrawable="@drawable/ic_note"
                        app:startIconTint="#4A67E0">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etItemNote"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:minLines="2"
                            android:gravity="top"
                            android:textColor="#1A1A2E"
                            android:textSize="15sp" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:id="@+id/TvPnoteMessage"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:layout_marginBottom="12dp"
                        android:text=""
                        android:textColor="#E53935"
                        android:textSize="12sp" />

                    <!-- Item Price -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:hint="Price ($)"
                        app:boxBackgroundColor="#F5F7FF"
                        app:boxBackgroundMode="filled"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxStrokeColor="#4A67E0"
                        app:hintTextColor="#4A67E0"
                        app:startIconDrawable="@drawable/ic_price"
                        app:startIconTint="#4A67E0"
                        app:prefixText="$"
                        app:prefixTextColor="#4A67E0">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etItemPrice"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal"
                            android:textColor="#1A1A2E"
                            android:textSize="15sp" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:id="@+id/TvPpriceMessage"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text=""
                        android:textColor="#E53935"
                        android:textSize="12sp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Image section card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="24dp"
                app:cardElevation="8dp"
                app:strokeColor="#E8EEFF"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:text="Product Image"
                        android:textColor="#4A67E0"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <!-- Image preview -->
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="110dp"
                            android:layout_height="110dp"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="4dp"
                            app:strokeColor="#D0D8FF"
                            app:strokeWidth="1dp">

                            <ImageView
                                android:id="@+id/imageViewPicture"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:contentDescription="Product image preview"
                                android:scaleType="centerCrop"
                                android:background="#F0F4FF"
                                tools:srcCompat="@tools:sample/avatars" />
                        </com.google.android.material.card.MaterialCardView>

                        <!-- Image action buttons -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="16dp"
                            android:gravity="center">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnTakePic"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="match_parent"
                                android:layout_height="46dp"
                                android:layout_marginBottom="10dp"
                                android:text="📷  Camera"
                                android:textColor="#4A67E0"
                                android:textSize="14sp"
                                app:strokeColor="#4A67E0"
                                app:strokeWidth="1.5dp"
                                app:cornerRadius="12dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnGallery"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="match_parent"
                                android:layout_height="46dp"
                                android:text="🖼️  Gallery"
                                android:textColor="#4A67E0"
                                android:textSize="14sp"
                                app:strokeColor="#4A67E0"
                                app:strokeWidth="1.5dp"
                                app:cornerRadius="12dp" />

                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Submit button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddItem"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="10dp"
                android:backgroundTint="#4A67E0"
                android:text="✓  Create Item"
                android:textColor="#FFFFFF"
                android:textSize="17sp"
                android:textStyle="bold"
                android:elevation="6dp"
                app:cornerRadius="16dp" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>