<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/home_page_background"
    tools:context=".screens.HomePage">

    <TextView
        android:id="@+id/Title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:layout_marginTop="260dp"
        android:layout_marginEnd="32dp"
        android:fontFamily="sans-serif-black"
        android:gravity="center"
        android:text="Welcome to my website"
        android:textColor="#FFFFFF"
        android:textSize="34sp"
        android:shadowColor="#40000000"
        android:shadowDx="4"
        android:shadowDy="4"
        android:shadowRadius="6"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- כפתור הרשמה - עם אפקט Hover ולחיצה -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btSignUp"
        android:layout_width="280dp"
        android:layout_height="64dp"
        android:backgroundTint="#F2FFFFFF"
        android:insetTop="0dp"
        android:layout_marginTop="90dp"
        android:insetBottom="0dp"
        android:onClick="onClicksignUp"
        android:text="Sign Up"
        android:textAllCaps="false"
        android:textColor="#6A1B9A"
        android:textSize="18sp"
        android:textStyle="bold"
        app:cornerRadius="32dp"
        app:elevation="4dp"
        app:hoveredFocusedTranslationZ="8dp"
        app:rippleColor="#406A1B9A"
        app:layout_constraintBottom_toTopOf="@+id/btLogIn"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/Title"
        app:layout_constraintVertical_chainStyle="packed" />

    <!-- כפתור התחברות - משנה עובי מסגרת ב-Hover -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btLogIn"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="280dp"
        android:layout_height="64dp"
        android:layout_marginTop="20dp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:onClick="onClickLogIn"
        android:text="Log In"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        app:cornerRadius="32dp"
        app:rippleColor="#40FFFFFF"
        app:strokeColor="#FFFFFF"
        app:strokeWidth="2dp"
        app:layout_constraintBottom_toTopOf="@+id/details"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btSignUp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/details"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="40dp"
        android:onClick="onClickAudot"
        android:text="אודות האתר"
        android:textColor="#F3E5F5"
        android:textSize="15sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
