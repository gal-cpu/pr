<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".screens.CartList">

    <ImageView
        android:id="@+id/imageCardCart"
        android:layout_width="match_parent"
        android:layout_height="130dp"
        android:layout_marginStart="25dp"
        android:layout_marginEnd="25dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.073"
        app:srcCompat="@drawable/image_transition_page" />

    <TextView
        android:id="@+id/tvTitleCart"
        android:layout_width="211dp"
        android:layout_height="103dp"
        android:gravity="center"
        android:text="Cart"
        android:textColor="@color/white"
        android:textSize="35dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.17"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.095"
        tools:ignore="MissingConstraints" />

    <ImageView
        android:id="@+id/ivTitleIteams"
        android:layout_width="93dp"
        android:layout_height="95dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.811"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.094"
        app:srcCompat="@drawable/cart_page" />

    <!-- ===== SEARCH + SORT ROW ===== -->
    <LinearLayout
        android:id="@+id/searchAndFilterRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="14dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/imageCardCart">

        <!-- שדה חיפוש -->
        <EditText
            android:id="@+id/edSearch"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:layout_marginEnd="10dp"
            android:background="@drawable/search_edit_background"
            android:drawableEnd="@drawable/searchicon"
            android:drawablePadding="10dp"
            android:elevation="0dp"
            android:hint="Search items..."
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:paddingStart="16dp"
            android:paddingEnd="12dp"
            android:textColorHint="#A89DC8"
            android:textColor="#2D1F6E"
            android:textSize="14sp" />

        <!-- כפתור מיון -->
        <LinearLayout
            android:id="@+id/btnShowOptionsCart"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:background="@drawable/sort_btn_bg"
            android:clickable="true"
            android:elevation="0dp"
            android:focusable="true"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:importantForAccessibility="no"
                android:src="@android:drawable/ic_menu_manage"
                app:tint="#7B6DAA" />

        </LinearLayout>

    </LinearLayout>

    <!-- ===== DROPDOWN מיון ===== -->
    <LinearLayout
        android:id="@+id/optionsContainerCart"
        android:layout_width="180dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:background="@drawable/dropdown_bg"
        android:elevation="8dp"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="@+id/searchAndFilterRow"
        app:layout_constraintTop_toBottomOf="@+id/searchAndFilterRow">

        <TextView
            android:id="@+id/option1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="13dp"
            android:paddingBottom="13dp"
            android:text="Default order"
            android:textColor="#2D1F6E"
            android:textSize="14sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="#E8E4F4"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"/>

        <TextView
            android:id="@+id/option2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="13dp"
            android:paddingBottom="13dp"
            android:text="Price: high to low"
            android:textColor="#2D1F6E"
            android:textSize="14sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="#E8E4F4"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"/>

        <TextView
            android:id="@+id/option3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="13dp"
            android:paddingBottom="13dp"
            android:text="Price: low to high"
            android:textColor="#2D1F6E"
            android:textSize="14sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="#E8E4F4"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"/>

        <TextView
            android:id="@+id/option4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="13dp"
            android:paddingBottom="13dp"
            android:text="Top rated"
            android:textColor="#2D1F6E"
            android:textSize="14sp" />

    </LinearLayout>

    <!-- ===== RECYCLER VIEW ===== -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/RcCart"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="96dp"
        android:clipToPadding="false"
        android:paddingBottom="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/searchAndFilterRow" />

    <LinearLayout
        android:id="@+id/bottomContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:layout_marginEnd="25dp"
        android:layout_marginStart="25dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- הכפתור עבר להתחלה (שמאל) וקיבל משקל 1.5 כדי להיות ארוך יותר -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPayCart"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
            android:layout_width="0dp"
            android:layout_height="55dp"
            android:layout_weight="1.5"
            android:backgroundTint="#9575CD"
            app:cornerRadius="20dp"
            android:onClick="onClickOrder"
            android:text="@string/order"
            android:textAllCaps="false"
            android:layout_marginEnd="15dp"
            app:icon="@drawable/icon_pay_cart" />

        <!-- הטקסט עבר לסוף (ימין) עם משקל 1 -->
        <TextView
            android:id="@+id/tvPay"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="The price is: 0$"
        android:textSize="20sp"
        android:textColor="@color/black"
        android:gravity="end" />

    </LinearLayout>



</androidx.constraintlayout.widget.ConstraintLayout>