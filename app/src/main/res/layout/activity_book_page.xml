<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F5FF"
    tools:context=".screens.Book_page">

    <ImageView
        android:id="@+id/imageCard"
        android:layout_width="match_parent"
        android:layout_height="130dp"
        android:layout_marginStart="25dp"
        android:layout_marginEnd="25dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.073"
        app:srcCompat="@drawable/image_transition_page" />

    <TextView
        android:id="@+id/tvTitleIteams"
        android:layout_width="211dp"
        android:layout_height="103dp"
        android:gravity="center"
        android:text=""
        android:textColor="@color/white"
        android:textSize="35dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.17"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.095"
        tools:ignore="MissingConstraints" />

    <ImageView
        android:id="@+id/ivTitleIteams"
        android:layout_width="93dp"
        android:layout_height="95dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.811"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.094" />

    <!-- ===== SEARCH + SORT ROW ===== -->
    <LinearLayout
        android:id="@+id/searchAndFilterRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="14dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/imageCard">

        <!-- שדה חיפוש -->
        <EditText
            android:id="@+id/edSearch"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:layout_marginEnd="10dp"
            android:background="@drawable/search_edit_background"
            android:drawableEnd="@drawable/searchicon"
            android:drawablePadding="10dp"
            android:elevation="0dp"
            android:hint="Search items..."
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:paddingStart="16dp"
            android:paddingEnd="12dp"
            android:textColorHint="#A89DC8"
            android:textColor="#2D1F6E"
            android:textSize="14sp" />

        <!-- כפתור מיון -->
        <LinearLayout
            android:id="@+id/btnShowOptionsBook"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:background="@drawable/sort_btn_bg"
            android:clickable="true"
            android:elevation="0dp"
            android:focusable="true"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:importantForAccessibility="no"
                android:src="@android:drawable/ic_menu_manage"
                app:tint="#7B6DAA" />

        </LinearLayout>

    </LinearLayout>

    <!-- ===== DROPDOWN מיון ===== -->
    <LinearLayout
        android:id="@+id/optionsContainerBook"
        android:layout_width="180dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:background="@drawable/dropdown_bg"
        android:elevation="8dp"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="@+id/searchAndFilterRow"
        app:layout_constraintTop_toBottomOf="@+id/searchAndFilterRow">

        <TextView
            android:id="@+id/optionBook1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="13dp"
            android:paddingBottom="13dp"
            android:text="Default order"
            android:textColor="#2D1F6E"
            android:textSize="14sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="#E8E4F4"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"/>

        <TextView
            android:id="@+id/optionBook2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="13dp"
            android:paddingBottom="13dp"
            android:text="Price: high to low"
            android:textColor="#2D1F6E"
            android:textSize="14sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="#E8E4F4"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"/>

        <TextView
            android:id="@+id/optionBook3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="13dp"
            android:paddingBottom="13dp"
            android:text="Price: low to high"
            android:textColor="#2D1F6E"
            android:textSize="14sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="#E8E4F4"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"/>

        <TextView
            android:id="@+id/optionBook4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="13dp"
            android:paddingBottom="13dp"
            android:text="Top rated"
            android:textColor="#2D1F6E"
            android:textSize="14sp" />

    </LinearLayout>

    <!-- ===== RECYCLER VIEW ===== -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rcItemes"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="16dp"
        android:clipToPadding="false"
        android:paddingBottom="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/searchAndFilterRow" />

</androidx.constraintlayout.widget.ConstraintLayout>