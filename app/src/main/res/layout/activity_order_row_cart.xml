<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
xmlns:app="http://schemas.android.com/apk/res-auto"
xmlns:tools="http://schemas.android.com/tools"
android:id="@+id/main"
android:layout_width="match_parent"
android:layout_height="wrap_content"
android:layout_margin="8dp"
app:cardBackgroundColor="#746F72"
app:cardCornerRadius="12dp"
app:cardElevation="4dp"
tools:context=".OrderRowCart">

<androidx.constraintlayout.widget.ConstraintLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp">

    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#0A0F0D"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp"
        android:gravity="center"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tvOrderIdValueO"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="12345"
            android:textColor="#9BD1E5"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tvOrderIdO"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="הזמנה:   "
            android:textColor="#9BD1E5"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>

    <androidx.cardview.widget.CardView
        android:id="@+id/cardBuyerInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        app:cardBackgroundColor="#9BD1E5"
        app:cardCornerRadius="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerLayout">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="פרטי רוכש"
                android:textColor="#0A0F0D"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_gravity="end" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#0A0F0D"
                android:layout_marginVertical="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layoutDirection="rtl">

                <TextView
                    android:id="@+id/tvUserO"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="שם מלא: "
                    android:textColor="#0A0F0D"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvUserValueO"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ישראל ישראלי"
                    android:textColor="#0A0F0D" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layoutDirection="rtl">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="טלפון: "
                    android:textColor="#0A0F0D"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvBuyerPhone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0501234567"
                    android:textColor="#0A0F0D" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:id="@+id/cardPurchaseDetails"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        app:cardBackgroundColor="#E1CA96"
        app:cardCornerRadius="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cardBuyerInfo">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="פרטי רכישה"
                android:textColor="#0A0F0D"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_gravity="end" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#0A0F0D"
                android:layout_marginVertical="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layoutDirection="rtl">

                <!-- אזור פרטי רכישה מימין -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvTimestampO"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="תאריך: "
                            android:textColor="#0A0F0D"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvTimestampValueO"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="13/05/2025"
                            android:textColor="#0A0F0D" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvTotalPriceO"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="סכום כולל: "
                            android:textColor="#0A0F0D"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvTotalPriceValueO"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₪149.90"
                            android:textColor="#0A0F0D" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="אמצעי תשלום: "
                            android:textColor="#0A0F0D"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvPaymentMethod"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Bit"
                            android:textColor="#0A0F0D" />
                    </LinearLayout>
                </LinearLayout>

                <!-- קו מפריד אנכי -->
                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="#0A0F0D"
                    android:layout_marginHorizontal="8dp" />

                <!-- אזור רשימת מוצרים משמאל -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layoutDirection="rtl">

                    <TextView
                        android:id="@+id/productsValue"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="פירוט מוצרים"
                        android:textColor="#0A0F0D"
                        android:textStyle="bold"
                        android:gravity="right" />

                    <LinearLayout
                        android:id="@+id/productListContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layoutDirection="rtl"
                            android:layout_marginTop="4dp">

                            <androidx.recyclerview.widget.RecyclerView
                                android:id="@+id/rcOrderItem"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"/>

                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>