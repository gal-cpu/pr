<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginStart="25dp"
    android:layout_marginEnd="25dp"
    tools:context=".screens.Payment_page">

    <ImageView
        android:id="@+id/ivTitlepayment"
        android:layout_width="match_parent"
        android:layout_height="110dp"
        android:layout_marginTop="20dp"
        android:importantForAccessibility="no"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.0"
        app:srcCompat="@drawable/image_transition_page" />

    <TextView
        android:id="@+id/tvTitlePayment"
        android:layout_width="200dp"
        android:layout_height="60dp"
        android:text="Payment"
        android:textSize="40dp"
        android:gravity="center"
        android:textStyle="bold"
        android:textColor="@color/white"
        app:layout_constraintBottom_toBottomOf="@+id/ivTitlepayment"
        app:layout_constraintEnd_toEndOf="@+id/ivTitlepayment"
        app:layout_constraintStart_toStartOf="@+id/ivTitlepayment"
        app:layout_constraintTop_toTopOf="@+id/ivTitlepayment" />

    <EditText
        android:id="@+id/edId"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="25dp"
        android:background="#b380ff"
        android:gravity="left"
        android:hint="ID Number"
        android:paddingStart="30dp"
        android:textColorHint="@color/white"
        android:textSize="30dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/ivTitlepayment">
    </EditText>

    <EditText
        android:id="@+id/edfullNAme"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="15dp"
        android:background="#b380ff"
        android:gravity="left"
        android:hint="Full Name"
        android:paddingStart="30dp"
        android:textColorHint="@color/white"
        android:textSize="30dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/edId">

    </EditText>

    <EditText
        android:id="@+id/edNumberCard"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="15dp"
        android:background="#b380ff"
        android:gravity="left"
        android:hint="Number Cart"
        android:paddingStart="30dp"
        android:textColorHint="@color/white"
        android:textSize="30dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/edfullNAme">

    </EditText>

    <LinearLayout
        android:id="@+id/linearLayout2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp"
        android:orientation="horizontal"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/edNumberCard">

        <!-- Spinner חודש -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <Spinner
                android:id="@+id/spinnerMonth"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="#b380ff"
                android:hint="Month"
                android:padding="12dp"
                android:textColor="@color/white"
                android:textColorHint="@color/white" />
        </LinearLayout>

        <!-- Spinner שנה -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <Spinner
                android:id="@+id/spinnerYear"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="#b380ff"
                android:hint="Year"
                android:padding="12dp"
                android:textColor="@color/white"
                android:textColorHint="@color/white" />
        </LinearLayout>
    </LinearLayout>

    <EditText
        android:id="@+id/editTextCVV"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="#b380ff"
        android:layout_marginTop="15dp"
        android:gravity="left"
        android:hint="CVV"
        android:paddingStart="30dp"
        android:textColorHint="@color/white"
        android:textSize="30dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/linearLayout2">

    </EditText>

    <TextView
        android:id="@+id/tvPricePayment"
        android:layout_width="match_parent"
        android:layout_height="30dp"
        android:textColor="#000000"
        android:layout_marginTop="10dp"
        android:textSize="20dp"
        android:gravity="center"
        android:text="Total price:"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/editTextCVV">

    </TextView>

    <Button
        android:id="@+id/btnPayment"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Make a payment"
        android:layout_marginTop="10dp"
        android:gravity="center"
        android:textSize="25dp"
        android:backgroundTint="#b380ff"
        app:layout_constraintTop_toBottomOf="@+id/tvPricePayment">

    </Button>

    <TextView
        android:id="@+id/tvOptionOfPayment"
        android:layout_width="match_parent"
        android:layout_height="30dp"
        android:layout_marginTop="10dp"
        android:gravity="center"
        android:text="Option of payment"
        android:textColor="#000000"
        android:textSize="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnPayment">

    </TextView>

    <!-- מערכות תשלום -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:layout_marginTop="10dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@+id/tvOptionOfPayment">

        <ImageButton
            android:id="@+id/ibBit"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_margin="8dp"
            android:padding="8dp"
            android:scaleType="fitCenter"
            android:src="@drawable/bit" />

        <ImageButton
            android:id="@+id/ibPayPal"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_margin="8dp"
            android:padding="8dp"
            android:scaleType="fitCenter"
            android:src="@drawable/paypal" />

        <ImageButton
            android:id="@+id/ibPayBox"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_margin="8dp"
            android:padding="8dp"
            android:scaleType="fitCenter"
            android:src="@drawable/paybox" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>