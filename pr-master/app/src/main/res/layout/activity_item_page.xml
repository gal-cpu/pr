<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    tools:context=".Item_page">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- כרטיס תמונת "סטודיו" יוקרתי -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="400dp"
                app:cardCornerRadius="35dp"
                app:cardElevation="12dp"
                app:cardBackgroundColor="#F5F5F7">

                <ImageView
                    android:id="@+id/ivItemAddCart"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:adjustViewBounds="true"
                    android:padding="25dp"
                    android:scaleType="fitCenter"
                    android:transitionName="item_image"
                    tools:srcCompat="@tools:sample/avatars" />

                <View
                    android:layout_width="40dp"
                    android:layout_height="4dp"
                    android:layout_gravity="bottom|center_horizontal"
                    android:layout_marginBottom="12dp"
                    android:background="#E0E0E0"
                    android:backgroundTint="#B187F2" />
            </androidx.cardview.widget.CardView>

            <!-- פרטי המוצר -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="3dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tvNameItem"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Product Name"
                        android:textColor="#222222"
                        android:textSize="26sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvPriceItem"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="$0.00"
                        android:textColor="#B187F2"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="16dp"
                        android:background="#EEEEEE" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Description"
                        android:textColor="#888888"
                        android:textSize="13sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.1" />

                    <TextView
                        android:id="@+id/tvNoteItem"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:lineSpacingExtra="5dp"
                        android:text="Product description details..."
                        android:textColor="#555555"
                        android:textSize="16sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- אזור הדירוג -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="3dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvAverageRating"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Average Rating: 0.0"
                        android:textColor="#444444"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <RatingBar
                        android:id="@+id/ratingBarUser"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:numStars="5"
                        android:progressTint="#FFD700"
                        android:rating="0"
                        android:stepSize="0.5"
                        style="?android:attr/ratingBarStyle" />

                    <Button
                        android:id="@+id/btnSubmitRating"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Submit Review"
                        android:textColor="#B187F2"
                        android:textStyle="bold" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- בחירת כמות (Quantity Selector) - הוספתי כאן -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnMinusPage"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="55dp"
                    android:layout_height="55dp"
                    android:text="-"
                    android:textSize="20sp"
                    android:textColor="#B187F2"
                    app:cornerRadius="15dp"
                    app:strokeColor="#B187F2" />

                <TextView
                    android:id="@+id/tvQuantityPage"
                    android:layout_width="70dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="1"
                    android:textColor="#222222"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPlusPage"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="55dp"
                    android:layout_height="55dp"
                    android:text="+"
                    android:textSize="20sp"
                    android:textColor="#B187F2"
                    app:cornerRadius="15dp"
                    app:strokeColor="#B187F2" />
            </LinearLayout>

            <!-- כפתורי פעולה סופיים -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="24dp"
                android:orientation="vertical">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/CartItemBtn"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:text="Add to the Cart"
                    android:textAllCaps="false"
                    android:textSize="18sp"
                    app:cornerRadius="16dp"
                    app:backgroundTint="#B187F2"
                    app:icon="@drawable/baseline_shopping_cart_24"
                    app:iconGravity="textStart" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/AddTOFavBtn"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginTop="12dp"
                    android:text="Add to Favorites"
                    android:textColor="#B187F2"
                    app:strokeColor="#B187F2"
                    android:textAllCaps="false"
                    app:cornerRadius="16dp" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
