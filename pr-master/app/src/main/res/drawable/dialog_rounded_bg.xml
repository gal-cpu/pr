<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- צבע הרקע של התיבה (לבן נקי) -->
    <solid android:color="#FFFFFF" />

    <!-- רדיוס הפינות - ככל שהמספר גבוה יותר, הפינה מעוגלת יותר -->
    <corners android:radius="24dp" />

    <!-- ריווח פנימי כדי שהטקסט לא יידבק לקצוות -->
    <padding
        android:left="12dp"
        android:top="12dp"
        android:right="12dp"
        android:bottom="12dp" />
</shape>
