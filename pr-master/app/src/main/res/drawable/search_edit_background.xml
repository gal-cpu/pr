<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- שכבה 1: ה"צל" הכהה - מוסטת מעט למטה -->
    <item
        android:left="2dp"
        android:right="2dp"
        android:top="2dp"
        android:bottom="0dp">
        <shape android:shape="rectangle">
            <corners android:radius="50dp" />
            <!-- צבע אפור כהה שיוצר אשליית צל -->
            <solid android:color="#D1D1D1" />
        </shape>
    </item>

    <!-- שכבה 2: התיבה הלבנה המרכזית -->
    <item
        android:left="0dp"
        android:right="0dp"
        android:top="0dp"
        android:bottom="3dp"> <!-- הרווח כאן חושף את השכבה הכהה למטה -->
        <shape android:shape="rectangle">
            <corners android:radius="50dp" />
            <solid android:color="#FFFFFF" />
            <!-- מסגרת דקיקה למניעת היבלעות בלבן של המסך -->
            <stroke
                android:width="1dp"
                android:color="#F0F0F0" />
        </shape>
    </item>

</layer-list>
